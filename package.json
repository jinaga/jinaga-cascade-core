{
  "name": "@jinaga/cascade-core",
  "version": "0.9.7",
  "description": "Incremental, event-driven data pipeline system for Jinaga Cascade",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "smoke:node-esm": "node scripts/smoke-node-esm.mjs",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:types": "tsd --files \"src/test/**/*.test-d.ts\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "data-pipeline",
    "incremental-processing",
    "reactive",
    "data-transformation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinaga/jinaga-cascade-core.git"
  },
  "dependencies": {
    "@stablelib/base64": "^1.0.1",
    "@stablelib/sha512": "^1.0.1",
    "@stablelib/utf8": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsd": "^0.33.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.18.2"
  }
}
